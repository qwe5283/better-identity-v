<Window x:Class="BetterIdentityV.View.MaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:viewModel="clr-namespace:BetterIdentityV.ViewModel"
        Title="MaskWindow"
        Height="500"
        Width="800"
        d:DesignWidth="1920"
        d:DesignHeight="1080"
        AllowsTransparency="True"
        FontFamily="{DynamicResource TextThemeFontFamily}"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStyle="None"
        mc:Ignorable="d">
    <Window.DataContext>
        <viewModel:MaskWindowViewModel />
    </Window.DataContext>
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadedCommand}" CommandParameter="{Binding}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>
    
    <Window.Background>
        <SolidColorBrush Opacity="0" Color="#FF00B000" />
    </Window.Background>
    <Window.Style>
        <Style TargetType="Window">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Window">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Style>
    
    <AdornerDecorator ClipToBounds="True">
        <Grid>
            <!-- 1920x1080 -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*" /> <!-- 20 -->
                <ColumnDefinition Width="23*" /> <!-- 43 -->
                <ColumnDefinition Width="250*" /> <!-- 293 -->
                <ColumnDefinition Width="664*" /> <!-- 957 -->
                <ColumnDefinition Width="6*" /> <!-- 963, Middle -->
                <ColumnDefinition Width="36*" /> <!-- 999 -->
                <ColumnDefinition Width="901*" /> <!-- 1900 -->
                <ColumnDefinition Width="20*" /> <!-- 1920 -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="570*" /> <!-- 570 -->
                <RowDefinition Height="60*" /> <!-- 630 -->
                <RowDefinition Height="370*" /> <!-- 1000 -->
                <RowDefinition Height="80*" /> <!-- 1080 -->
            </Grid.RowDefinitions>
            
            <!-- 日志和状态 -->
            <Grid Grid.Column="1" Grid.Row="0" 
                  Grid.ColumnSpan="5" Grid.RowSpan="3"
                  HorizontalAlignment="Left" VerticalAlignment="Bottom"
                  Opacity="0.6" Height="213" Width="477">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25" />
                    <RowDefinition Height="188" />
                </Grid.RowDefinitions>
                <!-- 日志 -->
                <ContentControl x:Name="LogTextBoxWrapper"
                                Grid.Row="1"
                                Width="477" Height="188"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                >
                    <ContentControl.Effect>
                        <DropShadowEffect Opacity="0.4" BlurRadius="4" ShadowDepth="0" />
                    </ContentControl.Effect>
                    <RichTextBox x:Name="LogTextBox"
                                 Padding="0,5,0,0"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontFamily="Cascadia Mono, Consolas, Courier New, monospace, Microsoft Yahei"
                                 FontSize="12"
                                 Foreground="LightGray"
                                 IsHitTestVisible="False"
                                 VerticalScrollBarVisibility="Hidden"
                                 Visibility="{Binding Config.MaskWindowConfig.ShowLogBox, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <RichTextBox.Effect>
                            <DropShadowEffect 
                                Color="Black" 
                                BlurRadius="5" 
                                ShadowDepth="0" 
                                Opacity="0.8" />
                        </RichTextBox.Effect>
                        <d:FlowDocument FontFamily="{Binding FontFamily, ElementName=LogTextBox}" FontSize="{Binding FontSize, ElementName=LogTextBox}">
                            <Paragraph>
                                <Run>[00:00:00 INF] 更好的IDV</Run>
                                <LineBreak/>
                                <Run>[00:00:00 INF] 遮罩窗口已启动，游戏大小1920x1080，素材缩放1.00，DPI缩放1</Run>
                                <LineBreak/>
                                <Run>[00:00:01 INF] Never gonna give you up</Run>
                                <LineBreak/>
                                <Run>[00:00:01 INF] Never gonna let you down</Run>
                            </Paragraph>
                        </d:FlowDocument>
                    </RichTextBox>
                </ContentControl>
                <!-- 状态 -->
                <ContentControl x:Name="StatusWrapper"
                                Grid.Row="0"
                                Width="477" Height="24"
                                HorizontalAlignment="Left" VerticalAlignment="Top">
                    <ContentControl.Effect>
                        <DropShadowEffect Opacity="0.8" BlurRadius="4" ShadowDepth="0" Color="Black" />
                    </ContentControl.Effect>
                    <ui:ListView ItemsSource="{Binding StatusList}"
                                 Visibility="{Binding Config.MaskWindowConfig.ShowStatus, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 d:ItemsSource="{d:SampleData}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Focusable" Value="False" />
                                <Setter Property="IsHitTestVisible" Value="False" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.Resources>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Margin" Value="0,0,8,0" />
                                        </Style>
                                    </StackPanel.Resources>
                                    <TextBlock FontFamily="{StaticResource FgiIconFontFamily}"
                                               FontSize="14"
                                               Text="{Binding Name}">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Foreground" Value="LightGray" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsEnabled}" Value="True" />
                                                            <Condition Binding="{Binding IsHealthy}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Foreground" Value="LightGreen" />
                                                    </MultiDataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsEnabled}" Value="True" />
                                                            <Condition Binding="{Binding IsHealthy}" Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Foreground" Value="IndianRed" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ui:ListView>
                </ContentControl>
            </Grid>
            <!-- 中心线辅瞄 -->
            <Rectangle Grid.Row="0" Grid.Column="4"
                       Visibility="{Binding Config.MaskWindowConfig.ShowAimLine, Converter={StaticResource BooleanToVisibilityConverter}}"
                       Fill="DarkRed"
                       Opacity="0.2"
                       IsHitTestVisible="False"/>
            <!-- 冷却可视化 -->
            <Border Grid.Column="6" Grid.Row="0" Margin="24,0"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Background="#40000000"
                    CornerRadius="4"
                    Opacity="0.4"
                    Visibility="Visible">
                <TextBlock Margin="4"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="16"
                           Foreground="White"
                           Text="{Binding CooldownText}"/>
            </Border>
        </Grid>
    </AdornerDecorator>
    
</Window>
